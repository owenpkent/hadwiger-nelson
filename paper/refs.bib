% Bibliography for "Forcing-sterility of the realizable unit-distance lineage
% and a codegree obstruction to chi >= 6".
%
% Reference details verified against published sources (web check, June 2026):
%   - deGrey2018: Geombinatorics 28(1), 18-31 (2018).  CONFIRMED.
%   - Parts2020: Geombinatorics 29(3), 137-166 (2020); the citable 510-vertex
%       reduction, added in place of a bare Polymath16 wiki/blog reference.
%   - KostochkaYancey2014: JCTB 109, 73-101 (2014).  CONFIRMED.
%   - LathropRadziszowski2011: JCMCC 78, 119-128 (2011); establishes
%       F_v(2,2,2,2,2;4)=16. Replaces an earlier mis-citation to a
%       Xu-Liang-Radziszowski paper (which is not the primary source for 16).
%   - SpencerSzemerediTrotter1984: Graph Theory and Combinatorics (Bollobas ed.),
%       Academic Press, 293-303 (1984).  CONFIRMED (some sources give 294-304).
%   - Woodall1973: JCTA 14, 187-200 (1973).  CONFIRMED.

@article{deGrey2018,
  author  = {de Grey, Aubrey D. N. J.},
  title   = {The chromatic number of the plane is at least 5},
  journal = {Geombinatorics},
  year    = {2018},
  volume  = {28},
  number  = {1},
  pages   = {18--31},
  note    = {Preprint: arXiv:1804.02385}
}

@misc{Polymath16,
  author       = {{Polymath, D. H. J.}},
  title        = {Polymath16: The chromatic number of the plane},
  howpublished = {Online collaborative project, Polymath wiki and blog of
                  Dustin G. Mixon and Aubrey de Grey},
  year         = {2018},
  note         = {Reduced unit-distance graphs with chromatic number at least 5
                  to roughly 510 vertices}
}

@article{KostochkaYancey2014,
  author  = {Kostochka, Alexandr and Yancey, Matthew},
