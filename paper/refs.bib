  year    = {2014},
  volume  = {109},
  pages   = {73--101},
  note    = {Preprint: arXiv:1209.1050}
}

@article{LathropRadziszowski2011,
  author  = {Lathrop, Joel and Radziszowski, Stanis{\l}aw P.},
  title   = {Computing the {Folkman} number $F_v(2,2,2,2,2;4)$},
  journal = {Journal of Combinatorial Mathematics and Combinatorial Computing},
  year    = {2011},
  volume  = {78},
  pages   = {119--128},
  note    = {Establishes $F_v(2,2,2,2,2;4) = 16$ (Nenov had shown
